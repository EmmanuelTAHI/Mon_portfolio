{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/frontend-app/browser",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/proxy?path=:path*" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api/proxy?path=$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}